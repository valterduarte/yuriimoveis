# --- Public (NEXT_PUBLIC_*) — inlined into the browser bundle, never put secrets here ---
NEXT_PUBLIC_SITE_URL=https://corretoryuri.com.br
NEXT_PUBLIC_CLOUDINARY_CLOUD=dfl3eskr9
NEXT_PUBLIC_CLOUDINARY_PRESET=Yuri-upload
# Google Analytics measurement id (e.g. G-XXXXXXXXXX). Optional.
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# --- Server secrets — required at runtime, validated on boot (see lib/env.ts) ---
DATABASE_URL=postgresql://...
JWT_SECRET=...
ADMIN_USER=...
ADMIN_PASSWORD=...
# Gemini API key for the lead-assistant chat (read by @ai-sdk/google).
GOOGLE_GENERATIVE_AI_API_KEY=

# Google Maps JavaScript API key (used by listing pages map).
# Create at https://console.cloud.google.com, enable Maps JavaScript API,
# restrict by HTTP referrer (corretoryuri.com.br, *.vercel.app, http://localhost:3000).
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Google service account credentials (JSON contents on a single line).
# Used by scripts/submit-indexing.ts, scripts/verify-gsc-ownership.ts and
# scripts/debug-gsc-access.ts for Indexing API and Search Console access.
# Preferred over nextjs/service-account.json on disk (file fallback still works
# for local dev). To generate: paste the JSON contents in one line, single-quoted.
GOOGLE_SERVICE_ACCOUNT_JSON=

# Upstash Redis for durable rate-limiting across serverless instances.
# Provisioned via Vercel Marketplace (Storage > Upstash). Falls back to an
# in-memory limiter when both vars are absent — fine for local dev,
# bypassable in production. Required for /api/auth/login and /api/contato
# to be effective behind multiple Vercel function instances.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Email for admin password recovery (Resend). Without RESEND_API_KEY the
# "forgot password" flow degrades gracefully (no email is sent). EMAIL_FROM
# must be a verified Resend sender; it falls back to Resend's onboarding
# address. ADMIN_RECOVERY_EMAIL seeds the recovery address on the very first
# boot — afterwards it is managed from the admin Conta screen.
RESEND_API_KEY=
EMAIL_FROM=
ADMIN_RECOVERY_EMAIL=
