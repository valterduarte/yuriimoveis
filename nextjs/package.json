{
  "name": "corretor-yuri-nextjs",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "knip": "knip",
    "seed:blog": "tsx scripts/seed-blog.ts",
    "submit:indexing": "tsx scripts/submit-indexing.ts",
    "submit:indexing:queue": "tsx scripts/submit-indexing.ts --queue",
    "gsc:index-status": "tsx scripts/inspect-index-status.ts",
    "gsc:token": "tsx scripts/verify-gsc-ownership.ts token",
    "gsc:verify": "tsx scripts/verify-gsc-ownership.ts verify",
    "prepare": "cd .. && git config core.hooksPath nextjs/.husky || true"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,mjs,cjs}": "eslint --fix"
  },
  "dependencies": {
    "@googlemaps/markerclusterer": "^2.6.2",
    "@neondatabase/serverless": "^1.0.2",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.38.0",
    "@vercel/speed-insights": "^2.0.0",
    "@vis.gl/react-google-maps": "^1.8.3",
    "isomorphic-dompurify": "^3.14.0",
    "jsonwebtoken": "^9.0.3",
    "next": "^15.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-icons": "^5.4.0",
    "swiper": "^12.0.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.19",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/marked": "^5.0.2",
    "@types/node": "^25.5.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.20",
    "dotenv": "^17.4.2",
    "eslint": "^9.0.0",
    "eslint-config-next": "^15.1.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "gray-matter": "^4.0.3",
    "husky": "^9.1.7",
    "knip": "^6.12.0",
    "lint-staged": "^16.4.0",
    "marked": "^18.0.1",
    "postcss": "^8.4.49",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.5"
  }
}
