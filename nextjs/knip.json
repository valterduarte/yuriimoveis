{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "entry": [
    "app/**/{page,layout,loading,error,not-found,template,default,sitemap,robots,manifest,opengraph-image,icon,apple-icon}.{ts,tsx,js,jsx}",
    "app/**/route.{ts,js}",
    "middleware.{ts,js}",
    "next.config.{ts,js,mjs}",
    "scripts/**/*.{ts,js}"
  ],
  "project": [
    "app/**/*.{ts,tsx,js,jsx}",
    "components/**/*.{ts,tsx,js,jsx}",
    "lib/**/*.{ts,tsx,js,jsx}",
    "hooks/**/*.{ts,tsx,js,jsx}",
    "utils/**/*.{ts,tsx,js,jsx}",
    "data/**/*.{ts,tsx,js,jsx}",
    "types/**/*.{ts,tsx,js,jsx}"
  ],
  "ignoreDependencies": [
    "eslint-config-next",
    "husky",
    "sharp"
  ]
}
